# MongoDB Connection (use MongoDB Atlas for production)
MONGO_URL=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/?retryWrites=true&w=majority
DB_NAME=samyak_platform

# Public URL of your deployment (e.g. https://your-app.vercel.app)
NEXT_PUBLIC_BASE_URL=https://your-app.vercel.app

# CORS
CORS_ORIGINS=*

# JWT Secret - generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=your-strong-random-secret-here

# Notion Integration - get from https://www.notion.so/profile/integrations
NOTION_API_KEY=ntn_your_notion_integration_token
NOTION_VERSION=2022-06-28
